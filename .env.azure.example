# Azure Blob Storage Configuration
# ================================

# Azure Storage Account Details
# Option 1: Use connection string (recommended for development)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net

# Option 2: Use account name and key (for production)
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_account_key_here

# Container Names
# These should match the containers you created in Azure
AZURE_CONTAINER_PFP=pfp                          # For profile pictures
AZURE_CONTAINER_VIDEOS=videos                    # For video files
AZURE_CONTAINER_THUMBNAILS=thumbnails            # For thumbnail images

# ================================
# How to get Azure credentials:
# ================================
# 1. Go to: https://portal.azure.com
# 2. Find your Storage Account
# 3. Click "Access keys" in the left menu
# 4. Copy the connection string or Account name + key
#
# Container names should be lowercase and already created in Azure
# ================================

# Example usage in admin panel:
# 1. Go to Django admin: /admin/video/courseresourceazure/
# 2. Click "Add Course Resource (Azure)"
# 3. Select Course, Resource Type (pfp, video, or thumbnail)
# 4. Upload file or paste Azure URL
# 5. The file will automatically upload to the appropriate container
