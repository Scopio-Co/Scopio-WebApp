# Django settings
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=20.17.98.254.nip.io,20.17.98.254,127.0.0.1,localhost,scopio.in,www.scopio.in

# Frontend URL for redirects
FRONTEND_URL=http://localhost:5173
USE_HTTPS=False
FRONTEND_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://scopio-webapp.pages.dev
# Backend's own canonical URL (used to build the absolute Google OAuth redirect)
# Set this to the public URL of this Django server so google_start redirects the
# browser directly to the backend instead of going through the frontend proxy.
BACKEND_URL=http://localhost:8000

# Site domain for OAuth (using nip.io for IP-based domain)
SITE_DOMAIN=20.17.98.254.nip.io

# Google OAuth Credentials (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Neon PostgreSQL Database URL
DATABASE_URL=postgresql://username:password@hostname.neon.tech/database?sslmode=require

# Azure Storage Configuration
# Option 1: Connection String (Recommended)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account-name;AccountKey=your-account-key;EndpointSuffix=core.windows.net
# Option 2: Account Name + Key (alternative to connection string)
AZURE_STORAGE_ACCOUNT_NAME=your-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-account-key

# Container Names (must exist in Azure, lowercase)
AZURE_CONTAINER_PFP=pfp
AZURE_CONTAINER_VIDEOS=videos
AZURE_CONTAINER_THUMBNAILS=thumbnails