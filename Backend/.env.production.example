# ==========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ==========================================
# WARNING: Never commit this file with real secrets!
# Copy this to .env.production and fill in real values

# Django settings
DJANGO_SECRET_KEY="your-production-secret-key-min-50-chars"
DEBUG=False
ALLOWED_HOSTS=your-domain.com,your-ip-address

# Frontend URL for redirects (Production: Vercel)
FRONTEND_URL=https://your-frontend.vercel.app
USE_HTTPS=True
FRONTEND_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Site domain for OAuth callback
SITE_DOMAIN=your-domain.com

# Google OAuth Credentials (Get from Google Cloud Console)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Neon PostgreSQL Database URL
# Format: postgresql://user:password@hostname:5432/database?sslmode=require
DATABASE_URL=postgresql://username:password@hostname.neon.tech/database?sslmode=require

# Azure Storage Configuration
# Get from: Azure Portal > Storage Account > Access Keys
# Option 1: Connection String (Recommended)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account-name;AccountKey=your-account-key;EndpointSuffix=core.windows.net

# Option 2: Account Name + Key (alternative)
AZURE_STORAGE_ACCOUNT_NAME=your-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-account-key

# Container Names (must exist in Azure, lowercase only)
AZURE_CONTAINER_PFP=pfp
AZURE_CONTAINER_VIDEOS=videos
AZURE_CONTAINER_THUMBNAILS=thumbnails

# Redis Cache (optional, for production performance)
# REDIS_URL=redis://username:password@hostname:6379/0
