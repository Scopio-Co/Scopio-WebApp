{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://scopio.in/api/$1"
    },
    {
      "source": "/glogin/(.*)",
      "destination": "https://scopio.in/glogin/$1"
    },
    {
      "source": "/accounts/(.*)",
      "destination": "https://scopio.in/accounts/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "https://scopio.in/admin/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
